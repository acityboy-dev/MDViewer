<Window x:Class="MDViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:MDViewer.ViewModels"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Width="1360"
        Height="860"
        MinWidth="980"
        MinHeight="640"
        Background="Transparent"
        Foreground="{DynamicResource TextPrimaryBrush}"
        AllowsTransparency="False"
        AllowDrop="True"
        PreviewDragEnter="Root_DragEnter"
        PreviewDragOver="Root_DragOver"
        PreviewDragLeave="Root_DragLeave"
        PreviewDrop="Root_Drop"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            NonClientFrameEdges="None"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="WindowFrame"
            Background="{DynamicResource AppBackgroundBrush}"
            CornerRadius="18"
            ClipToBounds="True">
    <Grid x:Name="RootSurface"
          Background="Transparent"
          AllowDrop="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="TitleBarSurface"
                Grid.Row="0"
                Background="{DynamicResource TitleBarBrush}"
                BorderBrush="{DynamicResource HairlineBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="14,0,10,0">
                    <Border Width="24"
                            Height="24"
                            CornerRadius="6"
                            Background="{DynamicResource AccentBrush}">
                        <TextBlock Text="M"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="MDViewer"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolbarIconButtonStyle}"
                            Content="☰"
                            ToolTip="라이브러리 접기/펼치기"
                            Command="{Binding ToggleSidebarCommand}" />
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="열기"
                            Command="{Binding OpenFileCommand}" />
                    <Button Style="{StaticResource ToolbarIconButtonStyle}"
                            Content="↻"
                            ToolTip="다시 렌더링"
                            Command="{Binding ReloadCommand}" />
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="{Binding ModeLabel}"
                            Command="{Binding ToggleEditCommand}" />
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="저장"
                            Command="{Binding SaveCommand}" />
                    <TextBlock Text="{Binding CurrentFilePath}"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0">
                    <Button Style="{StaticResource ToolbarIconButtonStyle}"
                            Content="◐"
                            ToolTip="테마 전환"
                            Command="{Binding ToggleThemeCommand}" />
                    <Button Style="{StaticResource ToolbarIconButtonStyle}"
                            Content="⚙"
                            ToolTip="Inspector 접기/펼치기"
                            Command="{Binding ToggleInspectorCommand}" />
                </StackPanel>

                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource CaptionButtonStyle}"
                            Content="−"
                            Click="Minimize_Click" />
                    <Button Style="{StaticResource CaptionButtonStyle}"
                            Content="▢"
                            Click="Maximize_Click" />
                    <Button Style="{StaticResource CloseButtonStyle}"
                            Content="×"
                            Click="Close_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="BodySurface"
              Grid.Row="1"
              Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding SidebarWidth}" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="{Binding InspectorWidth}" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource SurfacePanelStyle}"
                    Opacity="{Binding SidebarOpacity}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="16,14,16,10">
                        <StackPanel>
                            <TextBlock Text="라이브러리"
                                       Style="{StaticResource PanelTitleStyle}" />
                            <TextBlock Text="최근 Markdown 파일"
                                       Style="{StaticResource PanelSubtitleStyle}" />
                        </StackPanel>
                        <Button HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Style="{StaticResource ToolbarIconButtonStyle}"
                                Content="‹"
                                ToolTip="라이브러리 접기"
                                Command="{Binding ToggleSidebarCommand}" />
                    </Grid>
                    <TabControl Grid.Row="1"
                                Style="{StaticResource MinimalTabControlStyle}">
                        <TabItem Header="파일">
                            <ListBox ItemsSource="{Binding RecentFiles}"
                                     SelectedItem="{Binding SelectedRecentFile}"
                                     Style="{StaticResource QuietListBoxStyle}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding FullPath}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>
                        <TabItem Header="목차">
                            <ListBox x:Name="OutlineListBox"
                                     ItemsSource="{Binding TableOfContents}"
                                     SelectionChanged="OutlineListBox_SelectionChanged"
                                     Style="{StaticResource QuietListBoxStyle}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Title}"
                                                   Margin="{Binding Indent}"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource DocumentHostStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="24,18,24,12"
                            BorderBrush="{DynamicResource HairlineBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="{Binding DocumentTitle}"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding DocumentSubtitle}"
                                           Margin="0,4,0,0"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock Text="{Binding RenderStatus}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Top"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontSize="12" />
                            <TextBlock Text="{Binding DirtyLabel}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Bottom"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="12" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Padding="18,10"
                            BorderBrush="{DynamicResource HairlineBrush}"
                            BorderThickness="0,0,0,1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <WrapPanel>
                            <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="H1" Tag="h1" Click="InsertMarkdown_Click" />
                            <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="H2" Tag="h2" Click="InsertMarkdown_Click" />
                            <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="B" Tag="bold" FontWeight="Bold" Click="InsertMarkdown_Click" />
                            <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="I" Tag="italic" FontStyle="Italic" Click="InsertMarkdown_Click" />
                            <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="`" Tag="code" Click="InsertMarkdown_Click" />
                            <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="{}{ }" Tag="codeblock" Click="InsertMarkdown_Click" />
                            <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="❝" Tag="quote" Click="InsertMarkdown_Click" />
                            <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="•" Tag="ul" Click="InsertMarkdown_Click" />
                            <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="1." Tag="ol" Click="InsertMarkdown_Click" />
                            <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="☐" Tag="task" Click="InsertMarkdown_Click" />
                            <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="🔗" Tag="link" Click="InsertMarkdown_Click" />
                            <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="▧" Tag="image" Click="InsertMarkdown_Click" />
                            <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="표" Tag="table" Click="InsertMarkdown_Click" />
                            <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="—" Tag="hr" Click="InsertMarkdown_Click" />
                        </WrapPanel>
                    </Border>

                    <Grid Grid.Row="2">
                        <FlowDocumentScrollViewer x:Name="DocumentViewer"
                                                  Document="{Binding Document}"
                                                  Padding="28,18,28,24"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  Background="Transparent"
                                                  IsToolBarVisible="False"
                                                  PreviewMouseWheel="DocumentViewer_PreviewMouseWheel">
                            <FlowDocumentScrollViewer.Style>
                                <Style TargetType="FlowDocumentScrollViewer">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </FlowDocumentScrollViewer.Style>
                        </FlowDocumentScrollViewer>
                        <TextBox x:Name="EditorTextBox"
                                 Text="{Binding MarkdownText, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewMouseWheel="EditorTextBox_PreviewMouseWheel">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource MarkdownEditorTextBoxStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <Border Background="{DynamicResource EmptyStateBrush}"
                                CornerRadius="18"
                                Padding="34"
                                Width="430"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasDocument}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="문서를 기다리는 중"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center" />
                                <TextBlock Text="열기 또는 끌어놓기로 시작하세요."
                                           Margin="0,10,0,22"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <Button Content="Markdown 열기"
                                        Width="160"
                                        HorizontalAlignment="Center"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Command="{Binding OpenFileCommand}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="4"
                    Style="{StaticResource SurfacePanelStyle}"
                    Opacity="{Binding InspectorOpacity}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Inspector"
                                           Style="{StaticResource PanelTitleStyle}" />
                                <TextBlock Text="문서 및 스타일"
                                           Style="{StaticResource PanelSubtitleStyle}" />
                            </StackPanel>
                            <Button HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Style="{StaticResource ToolbarIconButtonStyle}"
                                    Content="›"
                                    ToolTip="Inspector 접기"
                                    Command="{Binding ToggleInspectorCommand}" />
                        </Grid>

                        <TextBlock Text="테마"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox ItemsSource="{Binding ThemeModeOptions}"
                                  DisplayMemberPath="Label"
                                  SelectedValuePath="Value"
                                  SelectedValue="{Binding SelectedThemeMode}"
                                  Style="{StaticResource SoftComboBoxStyle}" />

                        <TextBlock Text="타이포그래피"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox ItemsSource="{Binding TypographyPresetOptions}"
                                  DisplayMemberPath="Label"
                                  SelectedValuePath="Value"
                                  SelectedValue="{Binding SelectedTypographyPreset}"
                                  Style="{StaticResource SoftComboBoxStyle}" />

                        <TextBlock Text="한글 본문 폰트"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox ItemsSource="{Binding DocumentFontOptions}"
                                  DisplayMemberPath="Label"
                                  SelectedItem="{Binding SelectedDocumentFontOption}"
                                  Style="{StaticResource SoftComboBoxStyle}" />

                        <Separator Margin="0,18" />

                        <TextBlock Text="문서"
                                   Style="{StaticResource SectionLabelStyle}" />
                        <TextBlock Text="{Binding DocumentInfo}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="12" />

                        <Separator Margin="0,18" />

                        <CheckBox Content="파일 변경 감지"
                                  IsChecked="{Binding IsFileWatchingEnabled}"
                                  Style="{StaticResource SoftCheckBoxStyle}" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border x:Name="DropOverlay"
                Grid.RowSpan="2"
                Visibility="Collapsed"
                Background="#A6101520"
                IsHitTestVisible="False">
            <StackPanel Width="460"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Border Width="68"
                        Height="68"
                        CornerRadius="34"
                        HorizontalAlignment="Center"
                        Background="{DynamicResource AccentBrush}">
                    <TextBlock Text="↓"
                               FontSize="34"
                               FontWeight="SemiBold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,-4,0,0" />
                </Border>
                <TextBlock Text="놓으면 열립니다"
                           Margin="0,22,0,0"
                           FontSize="30"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           Foreground="White" />
                <TextBlock Text="작업 흐름은 그대로 이어집니다."
                           Margin="0,8,0,0"
                           FontSize="14"
                           TextAlignment="Center"
                           Foreground="#DDFFFFFF" />
            </StackPanel>
        </Border>
    </Grid>
    </Border>
</Window>
