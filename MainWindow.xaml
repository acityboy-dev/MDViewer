<Window x:Class="MDViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:MDViewer.ViewModels"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Icon="pack://application:,,,/Assets/MarkFlow-64.png"
        Width="1360"
        Height="860"
        MinWidth="980"
        MinHeight="640"
        Background="Transparent"
        Foreground="{DynamicResource TextPrimaryBrush}"
        AllowsTransparency="False"
        AllowDrop="True"
        PreviewDragEnter="Root_DragEnter"
        PreviewDragOver="Root_DragOver"
        PreviewDragLeave="Root_DragLeave"
        PreviewDrop="Root_Drop"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            NonClientFrameEdges="None"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="WindowFrame"
            Background="{DynamicResource AppBackgroundBrush}"
            CornerRadius="18"
            ClipToBounds="True">
    <Grid x:Name="RootSurface"
          Background="Transparent"
          AllowDrop="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="TitleBarSurface"
                Grid.Row="0"
                Background="{DynamicResource TitleBarBrush}"
                BorderBrush="{DynamicResource HairlineBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="14,0,10,0"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Image Source="pack://application:,,,/Assets/MarkFlow-64.png"
                           Width="26"
                           Height="26" />
                    <TextBlock Text="MarkFlow"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource ToolbarIconButtonStyle}"
                            ToolTip="{DynamicResource ToggleLibraryTooltip}"
                            Command="{Binding ToggleSidebarCommand}">
                        <Path Style="{StaticResource ToolbarPathStyle}"
                              Data="M2,3.5 L14,3.5 M2,8 L14,8 M2,12.5 L14,12.5" />
                    </Button>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="{DynamicResource Open}"
                            Command="{Binding OpenFileCommand}" />
                    <Button Style="{StaticResource ToolbarIconButtonStyle}"
                            ToolTip="{DynamicResource ReloadTooltip}"
                            Command="{Binding ReloadCommand}">
                        <Path Style="{StaticResource ToolbarPathStyle}"
                              Data="M13.5,5.5 L13.5,2 L10,2 M13.2,2.4 C11.9,1.2 10.1,0.8 8.3,1.1 C5.1,1.6 2.8,4.4 2.8,7.6 C2.8,11.3 5.8,14.2 9.4,14.2 C11.8,14.2 13.9,13 15,11.1" />
                    </Button>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="{Binding ModeLabel}"
                            Command="{Binding ToggleEditCommand}" />
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="{DynamicResource Save}"
                            Command="{Binding SaveCommand}" />
                    <TextBlock Text="{Binding CurrentFilePath}"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"
                               Cursor="Hand"
                               MouseLeftButtonUp="CurrentFilePath_MouseLeftButtonUp" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource ToolbarIconButtonStyle}"
                            ToolTip="{DynamicResource ThemeTooltip}"
                            Click="ToggleTheme_Click">
                        <Path Style="{StaticResource ToolbarPathStyle}"
                              Data="M11.8,12.8 C7.9,13.3 4.6,10.3 4.6,6.5 C4.6,4.2 5.8,2.2 7.7,1.1 C4.1,1.3 1.3,4.3 1.3,8 C1.3,11.9 4.5,15 8.4,15 C11.1,15 13.5,13.5 14.7,11.2 C13.9,12 12.9,12.6 11.8,12.8 Z" />
                    </Button>
                    <Button Style="{StaticResource ToolbarIconButtonStyle}"
                            ToolTip="{DynamicResource SettingsTooltip}"
                            Click="Settings_Click">
                        <Path Width="14"
                              Height="14"
                              Stretch="Uniform"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M9.6,1.2 L10.1,3.1 C10.5,3.3 10.8,3.5 11.1,3.8 L13,3.3 L14.2,5.4 L12.8,6.8 C12.9,7.2 12.9,7.6 12.8,8 L14.2,9.6 L13,11.7 L11.1,11.2 C10.8,11.5 10.5,11.7 10.1,11.9 L9.6,13.8 L7.2,13.8 L6.7,11.9 C6.3,11.7 6,11.5 5.7,11.2 L3.8,11.7 L2.6,9.6 L4,8 C3.9,7.6 3.9,7.2 4,6.8 L2.6,5.4 L3.8,3.3 L5.7,3.8 C6,3.5 6.3,3.3 6.7,3.1 L7.2,1.2 Z M8.4,5.3 A2.1,2.1 0 1 0 8.4,9.5 A2.1,2.1 0 0 0 8.4,5.3 Z" />
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource CaptionButtonStyle}"
                            Click="Minimize_Click">
                        <Path Style="{StaticResource CaptionPathStyle}"
                              Data="M3,8 L13,8" />
                    </Button>
                    <Button Style="{StaticResource CaptionButtonStyle}"
                            Click="Maximize_Click">
                        <Path Style="{StaticResource CaptionPathStyle}"
                              Data="M4,4 L12,4 L12,12 L4,12 Z" />
                    </Button>
                    <Button Style="{StaticResource CloseButtonStyle}"
                            Click="Close_Click">
                        <Path Style="{StaticResource CaptionPathStyle}"
                              Data="M4.5,4.5 L11.5,11.5 M11.5,4.5 L4.5,11.5" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="BodySurface"
              Grid.Row="1"
              Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding SidebarWidth}" />
                <ColumnDefinition Width="{Binding SidebarGapWidth}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource SurfacePanelStyle}"
                    Opacity="{Binding SidebarOpacity}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="16,14,16,10">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource LibraryTitle}"
                                       Style="{StaticResource PanelTitleStyle}" />
                            <TextBlock Text="{DynamicResource LibrarySubtitle}"
                                       Style="{StaticResource PanelSubtitleStyle}" />
                        </StackPanel>
                        <Button HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Style="{StaticResource ToolbarIconButtonStyle}"
                                ToolTip="{DynamicResource CollapseLibraryTooltip}"
                                Command="{Binding ToggleSidebarCommand}">
                            <Path Style="{StaticResource ToolbarPathStyle}"
                                  Width="8"
                                  Height="13"
                                  Data="M7,1 L1,7 L7,13" />
                        </Button>
                    </Grid>
                    <TabControl Grid.Row="1"
                                Style="{StaticResource MinimalTabControlStyle}">
                        <TabItem Header="{DynamicResource FilesTab}">
                            <ListBox ItemsSource="{Binding RecentFiles}"
                                     SelectedItem="{Binding SelectedRecentFile}"
                                     Style="{StaticResource QuietListBoxStyle}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding FullPath}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>
                        <TabItem Header="{DynamicResource OutlineTab}">
                            <ListBox x:Name="OutlineListBox"
                                     ItemsSource="{Binding TableOfContents}"
                                     SelectionChanged="OutlineListBox_SelectionChanged"
                                     Style="{StaticResource QuietListBoxStyle}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Title}"
                                                   Margin="{Binding Indent}"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource DocumentHostStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="24,18,24,12"
                            BorderBrush="{DynamicResource HairlineBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="{Binding DocumentTitle}"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding DocumentSubtitle}"
                                           Margin="0,4,0,0"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock Text="{Binding RenderStatus}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Top"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontSize="12" />
                            <TextBlock Text="{Binding DirtyLabel}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Bottom"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="12" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Padding="18,10"
                            BorderBrush="{DynamicResource HairlineBrush}"
                            BorderThickness="0,0,0,1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Left"
                                        Orientation="Horizontal"
                                        Margin="0,0,14,0">
                                <TextBlock Text="{DynamicResource WritingTools}"
                                           Margin="0,0,10,0"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <ComboBox Width="144"
                                          Style="{StaticResource SoftComboBoxStyle}"
                                          ItemsSource="{Binding EditorModeOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding SelectedEditorMode}" />
                            </StackPanel>
                            <WrapPanel>
                                <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="H1" Tag="h1" ToolTip="{DynamicResource ToolHeading1}" Click="InsertMarkdown_Click" />
                                <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="H2" Tag="h2" ToolTip="{DynamicResource ToolHeading2}" Click="InsertMarkdown_Click" />
                                <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="B" Tag="bold" FontWeight="Bold" ToolTip="{DynamicResource ToolBold}" Click="InsertMarkdown_Click" />
                                <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="I" Tag="italic" FontStyle="Italic" ToolTip="{DynamicResource ToolItalic}" Click="InsertMarkdown_Click" />
                                <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="`" Tag="code" ToolTip="{DynamicResource ToolInlineCode}" Click="InsertMarkdown_Click" />
                                <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="{}{ }" Tag="codeblock" ToolTip="{DynamicResource ToolCodeBlock}" Click="InsertMarkdown_Click" />
                                <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="❝" Tag="quote" ToolTip="{DynamicResource ToolQuote}" Click="InsertMarkdown_Click" />
                                <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="•" Tag="ul" ToolTip="{DynamicResource ToolBulletList}" Click="InsertMarkdown_Click" />
                                <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="1." Tag="ol" ToolTip="{DynamicResource ToolNumberedList}" Click="InsertMarkdown_Click" />
                                <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="☐" Tag="task" ToolTip="{DynamicResource ToolTask}" Click="InsertMarkdown_Click" />
                                <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="Link" Tag="link" ToolTip="{DynamicResource ToolLink}" Click="InsertMarkdown_Click" />
                                <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="Img" Tag="image" ToolTip="{DynamicResource ToolImage}" Click="InsertMarkdown_Click" />
                                <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="Tbl" Tag="table" ToolTip="{DynamicResource ToolTable}" Click="InsertMarkdown_Click" />
                                <Button Style="{StaticResource MarkdownToolButtonStyle}" Content="—" Tag="hr" ToolTip="{DynamicResource ToolRule}" Click="InsertMarkdown_Click" />
                            </WrapPanel>
                        </DockPanel>
                    </Border>

                    <Grid Grid.Row="2">
                        <FlowDocumentScrollViewer x:Name="DocumentViewer"
                                                  Document="{Binding Document}"
                                                  Padding="30,20,30,24"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  Background="Transparent"
                                                  IsToolBarVisible="False"
                                                  PreviewMouseWheel="DocumentViewer_PreviewMouseWheel">
                            <FlowDocumentScrollViewer.Style>
                                <Style TargetType="FlowDocumentScrollViewer">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </FlowDocumentScrollViewer.Style>
                        </FlowDocumentScrollViewer>
                        <Grid Margin="20">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="{Binding EditorPreviewGapWidth}" />
                                <ColumnDefinition Width="{Binding EditorPreviewWidth}" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="EditorTextBox"
                                     Grid.Column="0"
                                     Text="{Binding MarkdownText, UpdateSourceTrigger=PropertyChanged}"
                                     PreviewMouseWheel="EditorTextBox_PreviewMouseWheel"
                                     Style="{StaticResource MarkdownEditorTextBoxStyle}" />
                            <Border Grid.Column="2"
                                    Background="{DynamicResource SurfaceBrush}"
                                    CornerRadius="14"
                                    ClipToBounds="True">
                                <FlowDocumentScrollViewer Document="{Binding EditorPreviewDocument}"
                                                          Padding="24,18,24,22"
                                                          VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          Background="Transparent"
                                                          IsToolBarVisible="False" />
                            </Border>
                        </Grid>
                        <Border HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,18,28,0"
                                Padding="14,8"
                                CornerRadius="18"
                                Background="{DynamicResource AccentSoftBrush}"
                                Panel.ZIndex="5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDirty}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="7"
                                         Height="7"
                                         Margin="0,0,8,0"
                                         VerticalAlignment="Center"
                                         Fill="{DynamicResource AccentBrush}" />
                                <TextBlock Text="{DynamicResource UnsavedChanges}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource EmptyStateBrush}"
                                CornerRadius="18"
                                Padding="34"
                                Width="430"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasDocument}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource EmptyTitle}"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center" />
                                <TextBlock Text="{DynamicResource EmptySubtitle}"
                                           Margin="0,10,0,22"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <Button Content="{DynamicResource OpenMarkdown}"
                                        Width="160"
                                        HorizontalAlignment="Center"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Command="{Binding OpenFileCommand}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

        </Grid>

        <Border x:Name="DropOverlay"
                Grid.RowSpan="2"
                Visibility="Collapsed"
                Background="#A6101520"
                IsHitTestVisible="False">
            <StackPanel Width="460"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Border Width="68"
                        Height="68"
                        CornerRadius="34"
                        HorizontalAlignment="Center"
                        Background="{DynamicResource AccentBrush}">
                    <Path Width="28"
                          Height="28"
                          Stretch="Uniform"
                          Stroke="White"
                          StrokeThickness="1.8"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Data="M8,2 L8,12 M3.5,8 L8,12.5 L12.5,8 M2,15 L14,15" />
                </Border>
                <TextBlock Text="{DynamicResource DropTitle}"
                           Margin="0,22,0,0"
                           FontSize="30"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           Foreground="White" />
                <TextBlock Text="{DynamicResource DropSubtitle}"
                           Margin="0,8,0,0"
                           FontSize="14"
                           TextAlignment="Center"
                           Foreground="#DDFFFFFF" />
            </StackPanel>
        </Border>
    </Grid>
    </Border>
</Window>
