<Window x:Class="MDViewer.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="MarkFlow 설정"
        Width="460"
        Height="560"
        MinWidth="420"
        MinHeight="480"
        Background="Transparent"
        Foreground="{DynamicResource TextPrimaryBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Assets/MarkFlow-64.png">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            NonClientFrameEdges="None"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="WindowFrame"
            Background="{DynamicResource AppBackgroundBrush}"
            CornerRadius="18"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource TitleBarBrush}"
                    BorderBrush="{DynamicResource HairlineBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="설정"
                               Margin="18,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <Button Grid.Column="1"
                            Style="{StaticResource CloseButtonStyle}"
                            Click="Close_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Path Style="{StaticResource CaptionPathStyle}"
                              Data="M4.5,4.5 L11.5,11.5 M11.5,4.5 L4.5,11.5" />
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="22">
                    <TextBlock Text="보기"
                               Style="{StaticResource PanelTitleStyle}" />
                    <TextBlock Text="문서가 화면에 놓이는 방식을 조정합니다."
                               Style="{StaticResource PanelSubtitleStyle}" />

                    <TextBlock Text="테마"
                               Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox ItemsSource="{Binding ThemeModeOptions}"
                              DisplayMemberPath="Label"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding SelectedThemeMode}"
                              Style="{StaticResource SoftComboBoxStyle}" />

                    <TextBlock Text="타이포그래피"
                               Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox ItemsSource="{Binding TypographyPresetOptions}"
                              DisplayMemberPath="Label"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding SelectedTypographyPreset}"
                              Style="{StaticResource SoftComboBoxStyle}" />

                    <TextBlock Text="한글 본문 폰트"
                               Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox ItemsSource="{Binding DocumentFontOptions}"
                              DisplayMemberPath="Label"
                              SelectedItem="{Binding SelectedDocumentFontOption}"
                              Style="{StaticResource SoftComboBoxStyle}" />

                    <Separator Margin="0,22" />

                    <TextBlock Text="문서"
                               Style="{StaticResource PanelTitleStyle}" />
                    <TextBlock Text="{Binding DocumentInfo}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="12" />

                    <Separator Margin="0,22" />

                    <CheckBox Content="파일 변경 감지"
                              IsChecked="{Binding IsFileWatchingEnabled}"
                              Style="{StaticResource SoftCheckBoxStyle}" />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
